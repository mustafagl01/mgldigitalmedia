# API Configuration
# Replace with your Cloudflare Worker URL after deployment
VITE_API_URL=https://your-worker.your-subdomain.workers.dev

# Google OAuth (Optional - for Google sign-in)
# Configure these in Cloudflare Workers secrets instead:
# wrangler secret put GOOGLE_CLIENT_ID
# wrangler secret put GOOGLE_CLIENT_SECRET

# JWT Secret (Configure in Cloudflare Workers secrets)
# wrangler secret put JWT_SECRET

# Stripe Secret (Configure in Cloudflare Workers secrets)
# wrangler secret put STRIPE_SECRET_KEY
